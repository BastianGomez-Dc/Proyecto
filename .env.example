# =============================================
# CONFIGURACION DE LOGGING GLOBAL
# =============================================

# Formato de logs
logging.pattern.console=%d{yyyy-MM-dd HH:mm:ss} - %msg%n
logging.pattern.file=%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n

# Archivo de logs
logging.file.name=logs/application.log
logging.file.max-size=10MB
logging.file.max-history=10

# =============================================
# NOTAS IMPORTANTES
# =============================================

# 1. Reemplaza localhost con la IP/hostname del servidor MySQL si esta remoto
# 2. Los puertos deben estar disponibles (8080-8083)
# 3. Las bases de datos deben existir previamente (creadas por Docker o manualmente)
# 4. Los usuarios MySQL deben tener permisos apropiados
# 5. Para produccion, guarda las contrasenas en variables de entorno del sistema

# =============================================
# VARIABLES DE ENTORNO DEL SISTEMA (Alternativa)
# =============================================

# Exporta estas variables en bash:
# export DB_URL=jdbc:mysql://localhost:3308/componentes_db
# export DB_USER=componente_user
# export DB_PASS=componente_pass

# Luego usa en application.properties:
# spring.datasource.url=${DB_URL}
# spring.datasource.username=${DB_USER}
# spring.datasource.password=${DB_PASS}

# =============================================
# DOCKER COMPOSE - CREDENCIALES
# =============================================

# Usuarios para las bases de datos (segun docker-compose.yml):

# MySQL Usuarios:
# MYSQL_USER: usuario_user
# MYSQL_PASSWORD: usuario_pass
# MYSQL_ROOT_PASSWORD: root_password

# MySQL Componentes:
# MYSQL_USER: componente_user
# MYSQL_PASSWORD: componente_pass
# MYSQL_ROOT_PASSWORD: root_password

# MySQL TipoServicio:
# MYSQL_USER: tiposervicio_user
# MYSQL_PASSWORD: tiposervicio_pass
# MYSQL_ROOT_PASSWORD: root_password

# MySQL Mantencion:
# MYSQL_USER: mantencion_user
# MYSQL_PASSWORD: mantencion_pass
# MYSQL_ROOT_PASSWORD: root_password
