# Variables de Entorno - Ejemplo de Configuracion

# Este archivo muestra las variables de entorno necesarias para ejecutar cada microservicio.
# Copia los valores relevantes a tu archivo application.properties local.

# =============================================
# CONFIGURACION GENERAL COMPARTIDA
# =============================================

# Perfil de Spring
spring.profiles.active=dev

# =============================================
# MICROSERVICIO COMPUTADOR (Puerto 8080)
# =============================================

# Nombre de la aplicacion
spring.application.name=computador

# Configuracion de Base de Datos Computador
spring.datasource.url=jdbc:mysql://localhost:3308/componentes_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
spring.datasource.username=componente_user
spring.datasource.password=componente_pass
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# JPA/Hibernate
spring.jpa.hibernate.ddl-auto=none
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQL8Dialect

# Flyway (Migraciones)
spring.flyway.enabled=true
spring.flyway.locations=classpath:db/migration

# Servidor
server.port=8080
server.servlet.context-path=/

# Logging
logging.level.com.serviciotecnico.computador=INFO
logging.level.org.springframework.web=DEBUG
logging.level.org.hibernate.SQL=DEBUG

